@model List<GezGin.Models.Tour>
@{
    ViewData["Title"] = "Ana Sayfa";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- HERO -->
<section class="hero">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-7 hero-content">
                <div class="hero-badge">✈ Dünyayı Keşfet</div>
                <h1>Hayalindeki <span>Seyahate</span> Hazır Mısın?</h1>
                <p>GezGin ile dünyanın dört bir yanına unutulmaz turlar. Profesyonel rehberler, konforlu konaklama ve eşsiz deneyimler seni bekliyor.</p>
                <div class="d-flex gap-3 flex-wrap">
                    <a href="/Tour/Index" class="btn btn-primary-custom" style="display:inline-block; width:auto; padding: 0.9rem 2.5rem; border-radius:50px; font-weight:700; background: var(--accent); color:white; text-decoration:none; transition:all 0.3s;">
                        Turları Keşfet
                    </a>
                    <a href="/Booking/Create" class="btn" style="display:inline-block; width:auto; padding: 0.9rem 2.5rem; border-radius:50px; font-weight:700; background: rgba(255,255,255,0.15); color:white; text-decoration:none; backdrop-filter:blur(5px); border:2px solid rgba(255,255,255,0.3);">
                        <i class="fas fa-calendar-check me-2"></i>Rezervasyon Yap
                    </a>
                </div>
                <div class="hero-stats">
                    <div class="stat-item">
                        <span class="stat-number">50+</span>
                        <span class="stat-label">Destinasyon</span>
                    </div>
                    <div class="stat-item">
                        <span class="stat-number">10K+</span>
                        <span class="stat-label">Mutlu Yolcu</span>
                    </div>
                    <div class="stat-item">
                        <span class="stat-number">15+</span>
                        <span class="stat-label">Yıl Deneyim</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- FEATURED TOURS -->
<section style="padding: 5rem 0;">
    <div class="container">
        <div class="text-center">
            <h2 class="section-title">Öne Çıkan Turlar</h2>
            <div class="accent-line mx-auto"></div>
            <p class="section-subtitle">En çok tercih edilen ve yüksek puanlı turlarımız</p>
        </div>
        <div class="row g-4">
            @foreach (var tour in Model)
            {
                <div class="col-lg-4 col-md-6">
                    <div class="tour-card">
                        <div class="tour-card-img-wrapper">
                            <img src="@tour.ImageUrl" alt="@tour.TourName" class="tour-card-img" />
                            <span class="tour-badge-category">@tour.Category</span>
                        </div>
                        <div class="tour-card-body">
                            <h5 class="tour-card-title">@tour.TourName</h5>
                            <p class="tour-location">
                                <i class="fas fa-map-marker-alt"></i> @tour.City, @tour.Country
                            </p>
                            <p class="tour-desc">@tour.ShortDescription</p>
                            <div class="tour-meta">
                                <span><i class="fas fa-clock"></i> @tour.DurationDays Gün</span>
                                <span><i class="fas fa-users"></i> Max @tour.MaxPersons Kişi</span>
                                <span class="stars">
                                    @for (int i = 0; i < 5; i++)
                                    {
                                        if (i < (int)tour.Rating)
                                        {
                                            <i class="fas fa-star"></i>
                                        }
                                    }
                                    @tour.Rating
                                </span>
                            </div>
                            <div class="tour-footer">
                                <div class="tour-price">
                                    @tour.Price.ToString("N0") €
                                    <small>/kişi</small>
                                </div>
                                <a href="/Tour/Details/@tour.Id" class="btn-tour">
                                    Detaylar <i class="fas fa-arrow-right ms-1"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
        <div class="text-center mt-5">
            <a href="/Tour/Index" class="btn-tour" style="padding: 0.9rem 3rem; font-size: 1rem;">
                Tüm Turları Gör <i class="fas fa-arrow-right ms-2"></i>
            </a>
        </div>
    </div>
</section>

<!-- WHY US -->
<section class="bg-light-custom" style="padding: 5rem 0;">
    <div class="container">
        <div class="text-center">
            <h2 class="section-title">Neden GezGin?</h2>
            <div class="accent-line mx-auto"></div>
            <p class="section-subtitle">15 yılı aşkın deneyimimizle fark yaratıyoruz</p>
        </div>
        <div class="row g-4">
            <div class="col-lg-3 col-md-6 text-center">
                <div class="feature-icon"><i class="fas fa-shield-alt"></i></div>
                <h5 style="font-family: var(--font-display); color: var(--primary);">Güvenli Seyahat</h5>
                <p style="font-size: 0.88rem; color: var(--text-muted);">Tüm turlarımızda tam sigorta ve profesyonel rehber desteği.</p>
            </div>
            <div class="col-lg-3 col-md-6 text-center">
                <div class="feature-icon"><i class="fas fa-tag"></i></div>
                <h5 style="font-family: var(--font-display); color: var(--primary);">En İyi Fiyat</h5>
                <p style="font-size: 0.88rem; color: var(--text-muted);">Piyasadaki en rekabetçi fiyatları sunuyoruz, gizli ücret yok.</p>
            </div>
            <div class="col-lg-3 col-md-6 text-center">
                <div class="feature-icon"><i class="fas fa-headset"></i></div>
                <h5 style="font-family: var(--font-display); color: var(--primary);">7/24 Destek</h5>
                <p style="font-size: 0.88rem; color: var(--text-muted);">Seyahat boyunca her an yanınızdayız, nerede olursanız olun.</p>
            </div>
            <div class="col-lg-3 col-md-6 text-center">
                <div class="feature-icon"><i class="fas fa-star"></i></div>
                <h5 style="font-family: var(--font-display); color: var(--primary);">Kaliteli Konaklama</h5>
                <p style="font-size: 0.88rem; color: var(--text-muted);">Özenle seçilmiş oteller ve konforlu ulaşım araçları.</p>
            </div>
        </div>
    </div>
</section>

<!-- CTA BANNER -->
<section style="padding: 5rem 0; background: linear-gradient(135deg, var(--primary), #2a5298);">
    <div class="container text-center text-white">
        <h2 style="font-family: var(--font-display); font-size: 2.5rem; margin-bottom: 1rem;">Hayalindeki Tura Hemen Rezervasyon Yap!</h2>
        <p style="opacity: 0.85; margin-bottom: 2rem; font-size: 1.05rem;">Sınırlı kontenjanlar dolmadan yerinizi ayırtın.</p>
        <a href="/Booking/Create" class="btn-rezervasyon" style="padding: 1rem 3rem; font-size: 1rem;">
            <i class="fas fa-calendar-check me-2"></i> Hemen Rezervasyon Yap
        </a>
    </div>
</section>
