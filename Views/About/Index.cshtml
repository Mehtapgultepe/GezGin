@{
    ViewData["Title"] = "Hakkımızda";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- PAGE HERO -->
<div class="page-hero">
    <div class="container">
        <div class="breadcrumb-custom mb-3">
            <a href="/">Ana Sayfa</a>
            <span>/</span> Hakkımızda
        </div>
        <h1>Hakkımızda</h1>
        <p>2010'dan bu yana seyahat tutkunlarının yanındayız</p>
    </div>
</div>

<!-- STORY -->
<section>
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <div class="accent-line left"></div>
                <h2 class="section-title">Hikayemiz</h2>
                <p style="color: var(--text-muted); line-height: 1.9; margin-bottom: 1rem;">
                    GezGin, 2010 yılında İstanbul'da küçük bir seyahat ofisi olarak kuruldu. Kurucularımız,
                    insanlara sadece tatil değil, ömür boyu unutamayacakları deneyimler sunma hayaliyle yola çıktı.
                </p>
                <p style="color: var(--text-muted); line-height: 1.9; margin-bottom: 1rem;">
                    Bugün 50'den fazla destinasyona düzenlediğimiz turlarla, 10.000'i aşkın mutlu yolcuyu
                    hayallerindeki noktalara taşıdık. Her turumuzda kalite, güven ve unutulmaz deneyim ilkelerimizden ödün vermiyoruz.
                </p>
                <p style="color: var(--text-muted); line-height: 1.9;">
                    Deneyimli ekibimiz, seyahatinizin ilk adımından son adımına kadar yanınızda.
                    Çünkü biz sadece tur satmıyoruz; anılar yaratıyoruz.
                </p>

                <div class="row g-3 mt-3">
                    <div class="col-4 text-center">
                        <div style="font-family: var(--font-display); font-size: 2rem; font-weight: 700; color: var(--accent);">15+</div>
                        <div style="font-size: 0.82rem; color: var(--text-muted);">Yıl Deneyim</div>
                    </div>
                    <div class="col-4 text-center">
                        <div style="font-family: var(--font-display); font-size: 2rem; font-weight: 700; color: var(--accent);">10K+</div>
                        <div style="font-size: 0.82rem; color: var(--text-muted);">Mutlu Yolcu</div>
                    </div>
                    <div class="col-4 text-center">
                        <div style="font-family: var(--font-display); font-size: 2rem; font-weight: 700; color: var(--accent);">50+</div>
                        <div style="font-size: 0.82rem; color: var(--text-muted);">Destinasyon</div>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <img src="https://images.unsplash.com/photo-1469854523086-cc02fe5d8800?w=700"
                     alt="GezGin Ekibi" style="border-radius: var(--radius); width:100%; height:420px; object-fit:cover; box-shadow: var(--shadow);" />
            </div>
        </div>
    </div>
</section>

<!-- VALUES -->
<section class="bg-light-custom">
    <div class="container">
        <div class="text-center">
            <h2 class="section-title">Değerlerimiz</h2>
            <div class="accent-line mx-auto"></div>
            <p class="section-subtitle">Her turumuzda bu ilkelerle hareket ediyoruz</p>
        </div>
        <div class="row g-4">
            <div class="col-md-4 text-center">
                <div class="feature-icon"><i class="fas fa-heart"></i></div>
                <h5 style="font-family: var(--font-display); color: var(--primary);">Tutku</h5>
                <p style="font-size: 0.88rem; color: var(--text-muted);">Seyahat tutkumuzu her turumuzda yansıtıyor, en özel anları yaşatıyoruz.</p>
            </div>
            <div class="col-md-4 text-center">
                <div class="feature-icon"><i class="fas fa-handshake"></i></div>
                <h5 style="font-family: var(--font-display); color: var(--primary);">Güven</h5>
                <p style="font-size: 0.88rem; color: var(--text-muted);">Şeffaf fiyatlandırma ve dürüst iletişimle güveninizi kazanıyoruz.</p>
            </div>
            <div class="col-md-4 text-center">
                <div class="feature-icon"><i class="fas fa-award"></i></div>
                <h5 style="font-family: var(--font-display); color: var(--primary);">Kalite</h5>
                <p style="font-size: 0.88rem; color: var(--text-muted);">Her detayı özenle planlayarak en yüksek kalitede hizmet sunuyoruz.</p>
            </div>
        </div>
    </div>
</section>

<!-- TEAM -->
<section>
    <div class="container">
        <div class="text-center">
            <h2 class="section-title">Ekibimiz</h2>
            <div class="accent-line mx-auto"></div>
            <p class="section-subtitle">Seyahatinizi mükemmel kılan insanlar</p>
        </div>
        <div class="row g-4 justify-content-center">
            <div class="col-lg-3 col-md-6">
                <div class="team-card">
                    <div class="team-avatar"><i class="fas fa-user"></i></div>
                    <h5 style="font-family: var(--font-display); color: var(--primary);">Ahmet Yılmaz</h5>
                    <p style="color: var(--accent); font-size: 0.85rem; font-weight: 600;">Kurucu & CEO</p>
                    <p style="font-size: 0.83rem; color: var(--text-muted);">15 yıllık turizm sektörü deneyimi ile şirketimizi kuran vizyon sahibi lider.</p>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="team-card">
                    <div class="team-avatar"><i class="fas fa-user"></i></div>
                    <h5 style="font-family: var(--font-display); color: var(--primary);">Zeynep Kaya</h5>
                    <p style="color: var(--accent); font-size: 0.85rem; font-weight: 600;">Operasyon Müdürü</p>
                    <p style="font-size: 0.83rem; color: var(--text-muted);">Tur operasyonlarını kusursuz yöneten, detaycı ve deneyimli uzman.</p>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="team-card">
                    <div class="team-avatar"><i class="fas fa-user"></i></div>
                    <h5 style="font-family: var(--font-display); color: var(--primary);">Mehmet Demir</h5>
                    <p style="color: var(--accent); font-size: 0.85rem; font-weight: 600;">Baş Tur Rehberi</p>
                    <p style="font-size: 0.83rem; color: var(--text-muted);">6 dil bilen, 30 ülke gezmiş tutkulu seyahat rehberi.</p>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="team-card">
                    <div class="team-avatar"><i class="fas fa-user"></i></div>
                    <h5 style="font-family: var(--font-display); color: var(--primary);">Selin Arslan</h5>
                    <p style="color: var(--accent); font-size: 0.85rem; font-weight: 600;">Müşteri İlişkileri</p>
                    <p style="font-size: 0.83rem; color: var(--text-muted);">Müşteri memnuniyetini her şeyin önünde tutan, güleryüzlü uzman.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CONTACT FORM -->
<section class="bg-light-custom">
    <div class="container">
        <div class="row g-5 align-items-center">
            <div class="col-lg-5">
                <div class="accent-line left"></div>
                <h2 class="section-title">Bize Ulaşın</h2>
                <p style="color: var(--text-muted); margin-bottom: 2rem;">Sorularınız için bize yazın, en kısa sürede dönüş yapalım.</p>
                <ul style="list-style:none; padding:0;">
                    <li style="display:flex; gap:1rem; margin-bottom:1.2rem; align-items:center;">
                        <div style="width:45px; height:45px; background:var(--primary); border-radius:50%; display:flex; align-items:center; justify-content:center; color:var(--accent); flex-shrink:0;">
                            <i class="fas fa-map-marker-alt"></i>
                        </div>
                        <div>
                            <strong style="color:var(--primary);">Adres</strong><br/>
                            <span style="font-size:0.88rem; color:var(--text-muted);">Bağcılar Mah. No:42, İstanbul</span>
                        </div>
                    </li>
                    <li style="display:flex; gap:1rem; margin-bottom:1.2rem; align-items:center;">
                        <div style="width:45px; height:45px; background:var(--primary); border-radius:50%; display:flex; align-items:center; justify-content:center; color:var(--accent); flex-shrink:0;">
                            <i class="fas fa-phone"></i>
                        </div>
                        <div>
                            <strong style="color:var(--primary);">Telefon</strong><br/>
                            <span style="font-size:0.88rem; color:var(--text-muted);">+90 212 000 00 00</span>
                        </div>
                    </li>
                    <li style="display:flex; gap:1rem; align-items:center;">
                        <div style="width:45px; height:45px; background:var(--primary); border-radius:50%; display:flex; align-items:center; justify-content:center; color:var(--accent); flex-shrink:0;">
                            <i class="fas fa-envelope"></i>
                        </div>
                        <div>
                            <strong style="color:var(--primary);">E-posta</strong><br/>
                            <span style="font-size:0.88rem; color:var(--text-muted);">info@gezgin.com</span>
                        </div>
                    </li>
                </ul>
            </div>
            <div class="col-lg-7">
                <div class="booking-form-card">
                    <form>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Ad Soyad</label>
                                <input type="text" class="form-control" placeholder="Adınız" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">E-posta</label>
                                <input type="email" class="form-control" placeholder="E-postanız" />
                            </div>
                            <div class="col-12">
                                <label class="form-label">Konu</label>
                                <input type="text" class="form-control" placeholder="Mesajınızın konusu" />
                            </div>
                            <div class="col-12">
                                <label class="form-label">Mesaj</label>
                                <textarea class="form-control" rows="4" placeholder="Mesajınızı yazınız..."></textarea>
                            </div>
                            <div class="col-12">
                                <button type="button" class="btn-submit">
                                    <i class="fas fa-paper-plane me-2"></i> Mesaj Gönder
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>
